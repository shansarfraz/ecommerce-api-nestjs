# Database Configuration (Neon Postgres)
DB_HOST=your-project.region.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASS=your-database-password

# Optional: turn TypeORM schema sync on for very early dev. Default is off.
# TYPEORM_SYNC=false
# TYPEORM_MIGRATIONS_RUN=true

# Mock payment provider webhook secret (only used by the mock driver)
MOCK_WEBHOOK_SECRET=whsec_mock_dev

# Stripe (set PAYMENT_DRIVER=stripe to activate)
PAYMENT_DRIVER=mock
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key
JWT_REFRESH_SECRET=your-refresh-secret-key

# Application
PORT=3000
NODE_ENV=development

# Email driver (console | sendgrid)
EMAIL_DRIVER=console
SENDGRID_API_KEY=SG.your_key_here
EMAIL_FROM=noreply@yourmarketplace.com

# S3 / File uploads
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
